# Database (Neon.tech PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Auth
JWT_SECRET=your-secret-at-least-32-chars-long

# App URL (for CORS / redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Uploads (path relative to project root; used when BLOB is not set)
UPLOAD_PATH=./uploads/audio

# Vercel Blob (when set, images and audio are stored in Blob instead of filesystem)
# Create a Blob store in Vercel Dashboard → Storage → Add → Blob, then copy token here or use vercel env pull
# BLOB_READ_WRITE_TOKEN=

# Optional: VAPID keys for Web Push (generate with web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# YouTube: Data API key for playlist import (get from Google Cloud Console)
# YOUTUBE_API_KEY=

# External yt-dlp API (e.g. Railway) – when set, download-track uses it instead of local yt-dlp
# YT_DLP_API_URL=https://yt-dlp--api.up.railway.app
# YT_DLP_API_KEY=
# אם בשרת החיצוני נתיב Spotify שונה (ברירת מחדל: /spotify/download):
# YT_DLP_SPOTIFY_DOWNLOAD_PATH=/api/spotify/download
